# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
ALLOWED_CHANNEL_ID=-1001234567890
ALLOWED_USER_ID=123456789

# Providers
GROQ_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
XAI_API_KEY=
ELEVENLABS_API_KEY=

# Whisper/TTS keys (if using provider)
WHISPER_API_KEY=

# Market / on-chain
COINGECKO_API_KEY=
BINANCE_API_KEY=
WHALE_ALERT_API_KEY=

# Chroma directory (persistent)
CHROMA_DIR=./data/chroma

# S3 (Yandex Object Storage - S3 compatible)
S3_ENDPOINT=https://storage.yandexcloud.net
S3_BUCKET=your-bucket
S3_PREFIX=crypto-analyst/chroma
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ru-central1

# Render / deployment
WEBHOOK_BASE_URL=https://your-service.onrender.com
WEBHOOK_PATH=/webhook

# Misc
LOG_LEVEL=INFO
MAX_CONCURRENT_ANALYSES=3
